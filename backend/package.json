{
  "name": "nexuserp-backend",
  "version": "1.0.0",
  "description": "Production-grade NexusERP Operations Suite Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "render:build": "prisma generate --schema=prisma/schema.postgres.prisma && tsc",
    "render:start": "prisma db push --schema=prisma/schema.postgres.prisma && tsx prisma/seed.ts && node dist/index.js",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:postgres": "prisma generate --schema=prisma/schema.postgres.prisma",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:db:push": "prisma db push",
    "prisma:db:push:postgres": "prisma db push --schema=prisma/schema.postgres.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "jest --runInBand",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^6.4.1",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.19.2",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
