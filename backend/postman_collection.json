      "item": [
        {
          "name": "Login - Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@minierp.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login - Sales",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sales@minierp.com\",\n  \"password\": \"Sales123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Get Customers",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/customers?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api", "customers"] }
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Rajesh Sharma\",\n  \"businessName\": \"Apex Electronics Wholesalers\",\n  \"email\": \"contact@apexelectronics.com\",\n  \"mobile\": \"+91 9876543210\",\n  \"gstNumber\": \"27AAAAA0000A1Z5\",\n  \"customerType\": \"WHOLESALE\",\n  \"address\": \"Industrial Estate Phase 2, Mumbai\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/customers", "host": ["{{baseUrl}}"], "path": ["api", "customers"] }
          }
        }
      ]
    },
    {
      "name": "Products & Inventory",
      "item": [
        {
          "name": "Get Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] }
          }
        },
        {
          "name": "Adjust Stock IN",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PRODUCT_UUID\",\n  \"warehouseId\": \"WAREHOUSE_UUID\",\n  \"quantity\": 50,\n  \"movementType\": \"IN\",\n  \"reason\": \"Procurement bulk shipment received\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/inventory/adjust", "host": ["{{baseUrl}}"], "path": ["api", "inventory", "adjust"] }
          }
        }
      ]
    },
    {
      "name": "Sales Challans",
      "item": [
        {
          "name": "Get Challans",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/challans", "host": ["{{baseUrl}}"], "path": ["api", "challans"] }
          }
        },
        {
          "name": "Confirm Challan Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/challans/CHALLAN_ID/status", "host": ["{{baseUrl}}"], "path": ["api", "challans", "CHALLAN_ID", "status"] }
